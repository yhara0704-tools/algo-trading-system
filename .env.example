# Algo Trading Terminal — Environment Variables

# Price feed: Binance public WebSocket (no auth needed)
# Coinbase Advanced Trade WS requires JWT auth since 2023 — not used

# Polymarket — no auth needed for read-only market data

# Server
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING
LOG_LEVEL=INFO

# J-Quants API（日本株リアルタイムデータ）
# https://jpx-jquants.com/ でアカウント登録後、ダッシュボードからリフレッシュトークンを取得
# Googleアカウントでログインした場合はダッシュボードの「リフレッシュトークン」をコピー
JQUANTS_REFRESH_TOKEN=your_refresh_token_here
# メール/パスワード認証を使う場合（上記トークンがあれば不要）
# JQUANTS_MAIL=your_email@example.com
# JQUANTS_PASSWORD=your_password
